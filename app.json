{
  "expo": {
    "name": "imogo",
    "slug": "imogo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/img/favicon.png",
    "scheme": "imogo",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/img/adaptive-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#741781"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#730d83",
        "foregroundImage": "./assets/img/icon.png",
        "backgroundImage": "./assets/img/icon.png",
        "monochromeImage": "./assets/img/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/img/favicon.png",
      "backgroundColor": "#730d83",
      "themeColor": "#730d83",
      "lang":"pt-BR"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/img/adaptive-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#730d83",
          "dark": {
            "backgroundColor": "#730d83"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
